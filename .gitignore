# ==========================================
# ROOT .gitignore - FlightBooking_Project
# ==========================================

# ---- node_modules (áp dụng toàn dự án) ----
node_modules/
**/node_modules/

# ---- Backend (Spring Boot / Maven) ----
backend/target/
backend/.gradle/
backend/*.class
backend/.classpath
backend/.project
backend/.settings/
backend/.idea/
backend/*.iml
backend/src/main/resources/application-local.properties

# ---- Frontend Web (React / Vite) ----
frontend-web/dist/
frontend-web/build/
frontend-web/.env
frontend-web/.env.local
frontend-web/.env.*.local

# ---- Mobile App (React Native / Expo) ----
mobile-app/android/build/
mobile-app/android/.gradle/
mobile-app/android/local.properties
mobile-app/android/app/debug/
mobile-app/android/app/release/
mobile-app/android/app/*.keystore
mobile-app/android/app/*.jks
mobile-app/ios/build/
mobile-app/ios/Pods/
mobile-app/.expo/
mobile-app/.expo-shared/
mobile-app/dist/
mobile-app/*.orig.*

# ---- Biến môi trường / bí mật ----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# ---- Editor / IDE ----
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---- Hệ điều hành ----
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ---- Log / Debug ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
